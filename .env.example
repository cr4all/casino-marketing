# Contact form POST endpoint (default: local API; override for Formspree etc.)
VITE_CONTACT_ENDPOINT=/api/contact

# Public site URL for sitemap/canonical (no trailing slash)
VITE_SITE_URL=https://ascendraplatforms.com

# Admin platform
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-a-long-random-string
API_PORT=3001

# Set for production static + API server (npm start after npm run build)
# NODE_ENV=production
